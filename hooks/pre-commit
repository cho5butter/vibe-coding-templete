#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# pre-commit フック
# コミット前にリント・ビルド・テストをすべて実行し、
# 1つでも失敗したらコミットを拒否する
# =============================================================================

# プロジェクトルートを取得
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo ""
echo "========================================"
echo "  pre-commit: 品質ゲート実行中..."
echo "========================================"

# --- 1. リント・フォーマット（静的解析） ---
echo ""
echo "[1/3] リント・静的解析"
if ! bash "$REPO_ROOT/scripts/lint.sh"; then
    echo ""
    echo "!! リント・静的解析に失敗しました。修正してから再度コミットしてください。"
    exit 1
fi

# --- 2. ビルド確認 ---
echo ""
echo "[2/3] ビルド確認"
if ! bash "$REPO_ROOT/scripts/build.sh"; then
    echo ""
    echo "!! ビルドに失敗しました。修正してから再度コミットしてください。"
    exit 1
fi

# --- 3. テスト実行（単体・結合） ---
echo ""
echo "[3/3] テスト実行"
if ! bash "$REPO_ROOT/scripts/test.sh"; then
    echo ""
    echo "!! テストに失敗しました。修正してから再度コミットしてください。"
    exit 1
fi

echo ""
echo "========================================"
echo "  pre-commit: 品質ゲート すべてパス ✓"
echo "========================================"
